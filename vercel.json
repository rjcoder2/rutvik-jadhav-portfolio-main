{
  "buildCommand": "cd rutvik-jadhav-portfolio-main && npm run build",
  "outputDirectory": "rutvik-jadhav-portfolio-main/dist/client",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "^/(.*\\..*)$", "destination": "/$1" },
    { "source": "^/(.*)$", "destination": "/api/index" }
  ]
}
